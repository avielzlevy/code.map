{
  "name": "@code-map/nestjs",
  "version": "0.1.0",
  "description": "Progressive disclosure flow-mapping tool for NestJS applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "smoke": "ts-node test/smoke.ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.1.13"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "jest": "^29.0.0",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/spec/**/*.spec.ts"],
    "moduleNameMapper": {
      "@constants": "<rootDir>/src/constants/index",
      "@config": "<rootDir>/src/config/env-config",
      "@exceptions": "<rootDir>/src/exceptions/flow-mapper.exceptions",
      "@logger": "<rootDir>/src/logger/flow-logger",
      "@dto": "<rootDir>/src/dto/flow-mapper-config.dto"
    }
  }
}

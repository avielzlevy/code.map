{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2020",
    "sourceMap": false,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@constants": ["src/constants/index"],
      "@config": ["src/config/env-config"],
      "@exceptions": ["src/exceptions/flow-mapper.exceptions"],
      "@logger": ["src/logger/flow-logger"],
      "@dto": ["src/dto/flow-mapper-config.dto"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "lib": ["ES2020"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
